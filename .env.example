# Environment: development / production
ENVIRONMENT=development

# Timezone
TIMEZONE=Asia/Tokyo

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=n8n
N8N_DB_NAME=n8n
DIFY_DB_NAME=dify

# Redis Configuration
REDIS_PASSWORD=change_me_redis_password

# n8n Configuration
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=change_me_to_random_32_char_string

# Dify Configuration
DIFY_SECRET_KEY=change_me_to_random_secret_key
DIFY_CONSOLE_API_URL=http://localhost:5001
DIFY_SERVICE_API_URL=http://localhost:5001
DIFY_APP_API_URL=http://localhost:5001
DIFY_APP_WEB_URL=http://localhost:3000

# Weaviate Configuration
WEAVIATE_API_KEY=

# Logging
LOG_LEVEL=INFO
DEBUG=false
FLASK_DEBUG=false

# Discord Integration (Configure in n8n)
# DISCORD_BOT_TOKEN=your_discord_bot_token
# DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Notion Integration (Configure in n8n)
# NOTION_API_KEY=your_notion_integration_token
# NOTION_DATABASE_ID=your_notion_database_id

# Firecrawl API (Configure in n8n)
# FIRECRAWL_API_KEY=your_firecrawl_api_key
