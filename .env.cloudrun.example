# ============================================
# Cloud Run Simple デプロイ用環境変数
# ============================================
# このファイルをコピーして .env.cloudrun を作成してください
# cp .env.cloudrun.example .env.cloudrun

# ============================================
# GCP設定（必須）
# ============================================

# GCPプロジェクトID
GCP_PROJECT_ID=your-project-id

# デプロイリージョン
GCP_REGION=asia-northeast1

# ============================================
# n8n設定
# ============================================

# n8n暗号化キー（32文字以上のランダム文字列）
# 生成方法: openssl rand -base64 32
N8N_ENCRYPTION_KEY=your-random-32-character-encryption-key

# n8n Basic認証（オプション、空の場合は認証なし）
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your-secure-password

# ============================================
# Dify設定
# ============================================

# Difyシークレットキー（ランダム文字列）
# 生成方法: openssl rand -base64 32
DIFY_SECRET_KEY=your-random-secret-key

# ============================================
# Cloud Run設定（オプション）
# ============================================

# 最小インスタンス数（0=アクセスがない時は停止、コスト削減）
MIN_INSTANCES=0

# 最大インスタンス数
MAX_INSTANCES=2

# タイムゾーン
TIMEZONE=Asia/Tokyo

# ============================================
# Discord Bot設定（オプション）
# Discord Botを使う場合のみ設定
# ============================================

# Discord Bot Token
DISCORD_BOT_TOKEN=

# Discord Client ID
DISCORD_CLIENT_ID=

# 監視するチャンネルID（カンマ区切り、空の場合は全チャンネル）
MONITORED_CHANNELS=

# ============================================
# n8n Workflow設定（オプション）
# ============================================

# Dockerコンテナ名（ローカルでDocker使用時）
# デフォルト: n8n-simple
N8N_DOCKER_CONTAINER=n8n-simple

# ローカルのn8nデータディレクトリ（ワークフローのエクスポート元）
# Dockerを使っている場合は不要（自動検出）
# ローカルディレクトリを使う場合のみ設定
LOCAL_N8N_DIR=

# ワークフローをエクスポートするかどうか（true/false）
EXPORT_WORKFLOWS=true

# ============================================
# コスト最適化設定
# ============================================

# Cloud Storageのストレージクラス
# STANDARD: 標準、NEARLINE: 月1回未満のアクセス、COLDLINE: 3ヶ月に1回未満
STORAGE_CLASS=STANDARD

# ログの保持期間（日数）
LOG_RETENTION_DAYS=7

# ============================================
# デバッグ設定
# ============================================

# デバッグモード（true/false）
DEBUG=false

# 詳細なログ出力（true/false）
VERBOSE=false
