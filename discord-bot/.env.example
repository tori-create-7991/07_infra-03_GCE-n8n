# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# n8n Webhook Configuration
N8N_WEBHOOK_URL=http://localhost:5678/webhook/discord-events
# For production, use your n8n Cloud Run URL:
# N8N_WEBHOOK_URL=https://your-n8n-service-xxxx-xx.a.run.app/webhook/discord-events

# Optional: Specific channels to monitor (comma-separated channel IDs)
# Leave empty to monitor all channels
MONITORED_CHANNELS=

# Optional: Enable debug logging
DEBUG=false

# Node Environment
NODE_ENV=production
